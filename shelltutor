        '> overwrites, >> appends' \
        '> overwrite, >> append' \
        '> writes over, >> adds to the end' \
        '>> appends' \
        '> overwrites' \
        'one overwrites one appends' \
        '> replaces >> appends' || return $?

    ask_question \
        "Q3: Why does ${CMD}vim my notes.txt${RST} open two files instead of one?" \
