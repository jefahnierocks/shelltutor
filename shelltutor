stage2_verify_task() {
    [ -d "$SANDBOX/stage2/practice" ] || return 1
    return 0
}

stage2_gate() {
    show_screen <<EOF
${H1}STAGE 2 — GATE${RST}

${SUB}Recall${RST} (three questions, all three must be correct).
Then a ${SUB}practical task${RST}.
EOF

    ask_question \
        "Q1: What does ${CMD}cd ..${RST} do?" \
