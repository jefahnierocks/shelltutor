stage2_lesson_3() {
    lesson <<EOF
${H1}2.3 — paths: relative, absolute, dot, dot-dot${RST}

A ${SUB}path${RST} tells the shell where something is.

${SUB}Relative paths${RST} start where you are now:
  ${DIM}notes.txt${RST}            a file in this folder
  ${DIM}practice/notes.txt${RST}   a file inside a subfolder
  ${DIM}../notes.txt${RST}         a file in the parent folder
  ${DIM}./notes.txt${RST}          same as 'notes.txt' (the . is this folder)

${SUB}Absolute paths${RST} start from the root, with ${KEY}/${RST}:
  ${DIM}/etc/hosts${RST}
