stage2_lesson_1() {
    lesson <<EOF
${H1}2.1 — ls: what's in here${RST}

${CMD}ls${RST} lists files and folders in your current directory.

  ${CMD}ls${RST}            ${DIM}# names only${RST}
  ${CMD}ls -l${RST}         ${DIM}# long form (permissions, size, date)${RST}
