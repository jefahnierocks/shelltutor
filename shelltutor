    setup_stage_dir 4
    if [ ! -f "$SANDBOX/stage4/seed.txt" ]; then
        cat > "$SANDBOX/stage4/seed.txt" <<'EOF'
a small text file
to give the glob something to match
EOF
    fi
    rm -f "$SANDBOX/stage4/count.txt" 2>/dev/null

    while true; do
        show_screen <<EOF
${H1}STAGE 4 — GATE TASK${RST}

Work inside ${DIR}${SANDBOX}/stage4${RST}.

Do these:

  1. Use ${CMD}seq${RST} and a pipe to count from 1 to 100 and save
     the count to ${DIR}count.txt${RST}.
     ${DIM}(hint: ${CMD}seq 1 100 | wc -l > count.txt${RST}${DIM})${RST}

  2. Use a glob to list every ${DIR}*.txt${RST} file in this folder.

Then type ${CMD}check${RST}.

${DIM}I will check: count.txt exists and contains 100.${RST}

${INSTR}▶ Type ${CMD}check${INSTR} when done.${RST}
EOF
        practice "$SANDBOX/stage4"
        local rc=$?
        case "$rc" in
            "$RC_CHECK")
                if stage4_verify_task; then
