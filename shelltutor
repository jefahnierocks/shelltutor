        'go up one folder' \
        'goes up one level' \
        'go up one level' \
        'goes to the parent folder' \
        'go to the parent folder' \
        'parent folder' \
        'up one' \
        'up one folder' || return $?

    ask_question \
        "Q2: What does ${CMD}~${RST} mean in a path?" \
        'home' \
        'home folder' \
        'home directory' \
        'my home folder' \
        'my home directory' \
        'the home folder' \
        'the home directory' \
        '\$home' \
        'home dir' || return $?

    # shellcheck disable=SC2088  # literal ~/projects/notes is the expected learner answer (no tilde expansion intended here)
    ask_question \
        "Q3: If I'm in ${DIM}~/projects${RST} and I type ${CMD}cd notes${RST}, what folder am I in?" \
        '~/projects/notes' \
        '\$home/projects/notes' \
        'projects/notes' \
