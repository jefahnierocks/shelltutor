# ---------------------------------------------------------------------
# STAGE 5 — Ready for vimtutor
# ---------------------------------------------------------------------

stage5_intro() {
    lesson <<EOF
${H1}STAGE 5 — Ready for vimtutor${RST}

Four lessons, then a gate. By the end, you'll know the difference
between a command that prints-and-exits and one that takes over the
terminal; you'll be able to leave any of them deliberately; and you'll
understand why Vim has ${CMD}:w${RST}, ${CMD}:q${RST}, and ${CMD}:q!${RST}.

After the gate, this tutor hands you to ${CMD}vimtutor${RST} (if it's
installed on your system) — that is the next step.

${INSTR}▶ Type ${CMD}next${INSTR} to begin lesson 5.1.${RST}
EOF
}

stage5_lesson_1() {
    lesson <<EOF
${H1}5.1 — print-and-exit vs full-screen${RST}

Most of the commands you've used print output and return immediately:
  ${CMD}ls${RST}          ${CMD}date${RST}          ${CMD}wc -l file${RST}

Other commands ${EM}take over the screen${RST} until you exit them:
  ${CMD}man ls${RST}              ${DIM}# the manual page for ls${RST}
  ${CMD}less long-file.txt${RST}  ${DIM}# page through a long file${RST}
  ${CMD}vim file${RST}            ${DIM}# the Vim editor${RST}

While a full-screen program is running, the shell prompt is ${SUB}gone${RST}.
You're inside a program. The same keys may do different things there.

${SUB}Exit keys${RST}:
  ${CMD}man${RST}   →  press ${KEY}q${RST}
  ${CMD}less${RST}  →  press ${KEY}q${RST}
  ${CMD}vim${RST}   →  type ${CMD}:q${RST} then Enter (and friends — Lesson 5.3)

Try one:
  ${CMD}man ls${RST}
  ${DIM}(read a few lines; press ${KEY}q${DIM} to come back here.)${RST}

${INSTR}▶ When back at ${DIM}shelltutor>${INSTR}, type ${CMD}next${INSTR}.${RST}
EOF
}

stage5_lesson_2() {
    lesson <<EOF
${H1}5.2 — entering and leaving Vim${RST}

${CMD}vim${RST} is a text editor. Before you ${SUB}edit${RST} anything,
let's learn how to ${SUB}leave${RST}.

First, see if Vim is installed:
  ${CMD}command -v vim${RST}

If you got a path, Vim is there. If not, install it before continuing.

A safe entrance:
  ${CMD}vim --version${RST}     ${DIM}# prints version info and exits${RST}

A full Vim session:
  ${CMD}vim${RST}

This drops you into Vim with no file. To leave without doing anything,
type:
  ${CMD}:q${RST} then Enter

If Vim refuses (because you typed something by accident and now there
are unsaved changes), use the ${EM}discard${RST} form:
  ${CMD}:q!${RST} then Enter

${EM}You will need :q!${RST} the first few times you use Vim. Memorize it.

${INSTR}▶ Try ${CMD}vim --version${INSTR} and ${CMD}vim${INSTR} (then ${CMD}:q${INSTR}). Then ${CMD}next${INSTR}.${RST}
EOF
}

stage5_lesson_3() {
    lesson <<EOF
${H1}5.3 — buffer vs file${RST}

This is the most important idea in this stage.

When you open a file in Vim, Vim ${SUB}reads it into a buffer${RST} —
a copy in memory. Your keystrokes change the ${SUB}buffer${RST}, not
the file. The file on disk only changes when you ${SUB}write${RST} the
buffer back.

  ${SUB}file on disk${RST}  →  ${SUB}buffer in memory${RST}  →  ${SUB}file on disk${RST}
       (read)                  (edit)                     (write)

That's why Vim has separate commands for save and quit:

  ${CMD}:w${RST}    write the buffer to the file
  ${CMD}:q${RST}    quit (only if there are no unsaved changes)
  ${CMD}:q!${RST}   quit and discard unsaved changes
  ${CMD}:wq${RST}   write, then quit

${EM}Practice this on a file you don't mind editing.${RST}  A
${DIR}practice.txt${RST} fixture is in this stage's folder. Try:

  ${CMD}vim practice.txt${RST}
     type ${CMD}i${RST} to enter insert mode (vimtutor will teach modes)
     type a few letters
     press ${KEY}Esc${RST}
     type ${CMD}:q!${RST} then Enter
     ${CMD}cat practice.txt${RST}   ${DIM}# the file is unchanged${RST}

  ${CMD}vim practice.txt${RST}
     type ${CMD}i${RST}, then a few letters, ${KEY}Esc${RST}
     type ${CMD}:wq${RST}, Enter
     ${CMD}cat practice.txt${RST}   ${DIM}# now the file has changed${RST}

${INSTR}▶ Try both, then ${CMD}next${INSTR}.${RST}
EOF
}

stage5_lesson_4() {
    lesson <<EOF
${H1}5.4 — calling vimtutor${RST}

${CMD}vimtutor${RST} is itself a shell command. It launches Vim on a
${SUB}copy${RST} of a tutorial file so you can practice without
damaging the original.

Check whether it's installed:
  ${CMD}command -v vimtutor${RST}

If it prints a path, you're set.

If not, you can install it:
  - on Linux: install your distro's full ${SUB}vim${RST} package (often
    a ${SUB}vim-enhanced${RST} or ${SUB}vim${RST} (not ${SUB}vim-minimal${RST})
    package).
  - on macOS: Vim ships in macOS, but ${CMD}vimtutor${RST} may not be
    on PATH. ${CMD}brew install vim${RST} via Homebrew adds it.

This stage's gate runs through the file-vs-buffer exercise from 5.3
once more, then you'll be done.

${INSTR}▶ Type ${CMD}next${INSTR} to take Stage 5's gate.${RST}
EOF
}

# Stage 5 verification is two-phase. The script controls a known starting
# state for practice.txt and re-verifies between phases.

stage5_seed_practice() {
    setup_stage_dir 5
    echo before > "$SANDBOX/stage5/practice.txt"
}

stage5_verify_phase1() {
    # phase 1: learner opened, edited, did NOT save. File should still say 'before'.
    [ -f "$SANDBOX/stage5/practice.txt" ] || return 1
    local content
    content=$(cat "$SANDBOX/stage5/practice.txt" 2>/dev/null)
    [ "$content" = "before" ] || return 1
    return 0
}

stage5_verify_phase2() {
    # phase 2: learner opened, edited, SAVED. File should differ from 'before'.
    [ -f "$SANDBOX/stage5/practice.txt" ] || return 1
    local content
    content=$(cat "$SANDBOX/stage5/practice.txt" 2>/dev/null)
    [ "$content" != "before" ] || return 1
    # also: file should be non-empty
    [ -s "$SANDBOX/stage5/practice.txt" ] || return 1
    return 0
}

stage5_gate() {
    show_screen <<EOF
${H1}STAGE 5 — GATE${RST}

${SUB}Recall${RST} (three questions, all three must be correct).
Then a ${SUB}two-phase practical task${RST}.
EOF

    ask_question \
        "Q1: How do you exit ${CMD}man ls${RST}?" \
        'q' \
        'press q' \
        'type q' \
        'the q key' || return $?

    ask_question \
        "Q2: After ${CMD}vim notes.txt${RST}, what makes Vim write your edit to the file?" \
        ':w' \
        ':w<enter>' \
        ':w then enter' \
        ':wq' \
        ':wq<enter>' \
        ':wq then enter' \
        'write command' \
        ':write' \
        'colon w' || return $?

    ask_question \
        "Q3: If you open ${DIR}notes.txt${RST} in ${CMD}vim${RST}, type some letters, and quit with ${CMD}:q!${RST} — did the file on disk change?" \
        'no' \
        'no it did not' \
        'no it didnt' \
        "no it didn't" \
        'no the file did not change' \
        'no, the file did not change' \
        'unchanged' \
        'it did not change' || return $?

    # Phase 1: open, edit, discard. File must still read 'before' afterward.
    while true; do
        stage5_seed_practice
        show_screen <<EOF
${H1}STAGE 5 — GATE TASK (phase 1 of 2)${RST}

I've reset ${DIR}practice.txt${RST} to contain just the word ${SUB}before${RST}.

At the practice prompt:

  1. ${CMD}cat practice.txt${RST}        ${DIM}# confirm it says 'before'${RST}
  2. ${CMD}vim practice.txt${RST}
       ${CMD}i${RST}  ${DIM}# enter insert mode${RST}
       type a few letters
       ${KEY}Esc${RST}
       ${CMD}:q!${RST}  Enter   ${DIM}# discard your changes${RST}
  3. ${CMD}cat practice.txt${RST}        ${DIM}# should still say 'before'${RST}

Then type ${CMD}check${RST}.

${DIM}I will verify the file is still exactly 'before'.${RST}

${INSTR}▶ Type ${CMD}check${INSTR} when done.${RST}
EOF
        practice "$SANDBOX/stage5"
        local rc=$?
        case "$rc" in
            "$RC_CHECK")
                if stage5_verify_phase1; then
                    printf '\n%b✓ Phase 1 verified — the file was unchanged.%b\n\n' "$OK" "$RST"
                    break
                fi
                printf '\n%bThe file is no longer exactly ''before''.%b\n' "$EM" "$RST"
                printf '%b(Did you use %b:wq%b%b instead of %b:q!%b%b?)%b\n' \
                    "$SUB" "$CMD" "$RST" "$SUB" "$CMD" "$RST" "$SUB" "$RST"
                printf '%bI'\''ll reset it and we'\''ll try phase 1 again.%b\n\n' "$EM" "$RST"
                ;;
            "$RC_QUIT") return $rc ;;
            *) : ;;
        esac
    done

    # Phase 2: open, edit, save. File must differ from 'before' afterward.
    while true; do
        # Don't reset between phases — the learner should see their phase-1
        # 'before' state and edit forward from it.
        show_screen <<EOF
${H1}STAGE 5 — GATE TASK (phase 2 of 2)${RST}

Now save a real edit.

  1. ${CMD}vim practice.txt${RST}
       ${CMD}i${RST}, type at least one letter, ${KEY}Esc${RST}
       ${CMD}:wq${RST}  Enter   ${DIM}# write and quit${RST}
  2. ${CMD}cat practice.txt${RST}        ${DIM}# now it differs from 'before'${RST}

Then type ${CMD}check${RST}.

${DIM}I will verify the file is no longer exactly 'before'.${RST}

${INSTR}▶ Type ${CMD}check${INSTR} when done.${RST}
EOF
        practice "$SANDBOX/stage5"
        local rc=$?
        case "$rc" in
            "$RC_CHECK")
                if stage5_verify_phase2; then
                    printf '\n%b✓ Phase 2 verified — the file was written.%b\n\n' "$OK" "$RST"
                    printf '%b✓ Stage 5 cleared.%b\n\n' "$OK" "$RST"
                    save_progress 5
                    return 0
                fi
                printf '\n%bThe file still reads exactly ''before''.%b\n' "$EM" "$RST"
                printf '%b(Did you use %b:q!%b%b instead of %b:wq%b%b? Try again.)%b\n\n' \
                    "$SUB" "$CMD" "$RST" "$SUB" "$CMD" "$RST" "$SUB" "$RST"
                ;;
            "$RC_QUIT") return $rc ;;
            *) : ;;
        esac
    done
}

run_stage5() {
    local lessons=(stage5_intro stage5_lesson_1 stage5_lesson_2 stage5_lesson_3 stage5_lesson_4)
    local i=0
    while [ "$i" -lt "${#lessons[@]}" ]; do
        "${lessons[$i]}"
        local rc=$?
        case "$rc" in
            "$RC_NEXT")  ((i++)) ;;
            "$RC_SHOW")  : ;;
            "$RC_PREV")  i=$((i > 0 ? i - 1 : 0)) ;;
            *)         return "$rc" ;;
        esac
    done
    stage5_gate
}

# ---------------------------------------------------------------------
# Finale
# ---------------------------------------------------------------------

finale() {
    clear 2>/dev/null || printf '\n'
    cat <<EOF
${H1}You're ready for vimtutor.${RST}

Across five stages you have met:

  ${SUB}commands${RST}    echo, pwd, whoami, date, clear, exit,
                ls, cd, ~, .., touch, mkdir, rmdir,
                cat, less, cp, mv, rm,
                command -v, wc, seq, head, sort, grep,
                man, vim, vim --version, vimtutor
  ${SUB}keys${RST}        Tab, Up Arrow, Ctrl+C, Ctrl+L, q, Esc
  ${SUB}operators${RST}   ${CMD}|${RST} (pipe)  ${CMD}>${RST} (redirect)  ${CMD}>>${RST} (append)
                ${CMD}<${RST} (input)  ${CMD}*${RST} (glob)
  ${SUB}ideas${RST}       prompt vs program  ·  buffer vs file
                relative vs absolute paths
                file is not changed until the buffer is written

${SUB}What's next${RST}:

  ${CMD}vimtutor${RST}
    ${DIM}# the Vim tutor itself; about 30 minutes, hands-on${RST}

If ${CMD}vimtutor${RST} isn't installed:
  - Linux: install your distro's full vim package
    (Fedora: ${CMD}sudo dnf install vim-enhanced${RST}; Debian/Ubuntu: ${CMD}sudo apt install vim${RST})
  - macOS:  ${CMD}brew install vim${RST}

Re-take any stage at any time:
  ${CMD}shelltutor 1${RST}   ${DIM}# replay Stage 1${RST}

Sandbox stays at ${DIR}${SANDBOX}${RST} if you want to keep playing.

EOF
    # Clean up progress so the next plain `shelltutor` invocation starts from
    # Stage 1 unless `shelltutor N` is given.
    rm -f "$PROGRESS_FILE" 2>/dev/null || true
}

# ---------------------------------------------------------------------
# Stage dispatcher
# ---------------------------------------------------------------------

run_stage() {
    case "$1" in
        1) run_stage1 ;;
        2) run_stage2 ;;
        3) run_stage3 ;;
        4) run_stage4 ;;
        5) run_stage5 ;;
        *) return 1 ;;
    esac
}

# ---------------------------------------------------------------------
# main
# ---------------------------------------------------------------------

main() {
    local start
    case "${1:-}" in
        -h|--help) usage; exit 0 ;;
        '')
            start=$(($(read_progress) + 1))
            if [ "$start" -gt "$TOTAL_STAGES" ]; then
                # Everything passed — show finale and exit.
                setup_sandbox
                finale
                exit 0
            fi
            ;;
        [1-5])
            start=$1
            ;;
        *)
            echo "shelltutor: argument must be a stage number (1..5)." >&2
            usage >&2
            exit 1
            ;;
    esac

    setup_sandbox

    local s rc
    for ((s=start; s<=TOTAL_STAGES; s++)); do
        run_stage "$s"
        rc=$?
        if [ "$rc" -ne 0 ]; then
            # quit / interrupt — bail without finale; progress file already saved.
            exit 0
        fi
    done

    finale
}

main "$@"
