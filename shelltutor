    setup_stage_dir 3
    rm -f "$SANDBOX/stage3/notes.txt" "$SANDBOX/stage3/backup.txt" "$SANDBOX/stage3/done.txt" 2>/dev/null

    while true; do
        show_screen <<EOF
${H1}STAGE 3 — GATE TASK${RST}

You will work inside ${DIR}${SANDBOX}/stage3${RST}.

Do these, in order:

  1. create a file ${DIR}notes.txt${RST} containing the word ${SUB}hello${RST}
     ${DIM}(hint: ${CMD}echo hello > notes.txt${RST}${DIM})${RST}
  2. copy ${DIR}notes.txt${RST} to ${DIR}backup.txt${RST}
  3. rename ${DIR}notes.txt${RST} to ${DIR}done.txt${RST}
  4. remove ${DIR}backup.txt${RST}

Then type ${CMD}check${RST}. The script will look at the folder.

${DIM}I will check: done.txt exists with 'hello' in it; notes.txt and${RST}
${DIM}backup.txt are gone.${RST}

${INSTR}▶ Type ${CMD}check${INSTR} when done.${RST}
EOF
        practice "$SANDBOX/stage3"
        local rc=$?
        case "$rc" in
            "$RC_CHECK")
                if stage3_verify_task; then
                    printf '\n%b✓ Stage 3 cleared.%b\n\n' "$OK" "$RST"
