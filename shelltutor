#!/usr/bin/env bash
# shelltutor — a vimtutor prerequisite course in five mastery-gated stages.
#
# Usage:
#   shelltutor          resume where you left off
#   shelltutor N        enter stage N (1..5) for re-take or first-time
#   shelltutor -h       this help
#
# Inside lessons, type 'next' at the shelltutor> prompt to advance, 'prev'
# to go back, 'show' to redisplay, 'quit' to leave (progress is saved).
# At a gate task, type 'check' once you have completed the task; the
# script will verify and either pass you or ask you to try again.
#
# Each of the five stages closes with a gate: three recall questions
# (all three must be correct) and one practical task (verified by the
# script). Passing means passing — there is no skip, but there is also
# no time pressure and unlimited retries.
#
# Stage map (vimtutor prerequisite curriculum):
#   1  Where am I?                    echo, pwd, whoami, date, clear, exit
#   2  Paths and the filesystem       ls, cd, .., ~
#   3  Files and operations           touch, mkdir, cat, less, cp, mv, rm
#   4  Commands, streams, composition command -v, |, >, >>, *, wc, seq, ...
#   5  Ready for vimtutor             man, less (full-screen), vim, vimtutor
#
# Implementation invariants:
#   - one bash file, bash 3.2+, no installation, no network, no privilege
#   - tutor writes only inside $SANDBOX (default $HOME/.shelltutor)
#   - practice subshell `cd`s to a stage-specific subdir; HISTFILE is
#     sandboxed; PS1 is rewritten; navigation builtins are overridden
#   - the practice subshell is a real interactive bash, so the learner
#     retains their normal account authority inside it. The welcome
#     screen scopes the safety claim accordingly (per audit F-002)

set -u

# Bash version sanity check. The script uses features present since
# bash 3.2 (arrays, C-style for, process substitution, [[ =~ ]],
# ANSI-C $'\\e[...' quoting). macOS ships bash 3.2 by default and that
# is sufficient — no install step is required to run the tutor. The
# check below only catches truly ancient (bash < 3) systems with a
# clear diagnostic instead of a cryptic syntax error.
if [ "${BASH_VERSINFO[0]:-0}" -lt 3 ]; then
    printf 'shelltutor: requires bash 3.2 or later (found %s).\n' \
        "${BASH_VERSION:-unknown}" >&2
    exit 1
fi

# ---------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------

SANDBOX="${SHELLTUTOR_HOME:-$HOME/.shelltutor}"
PROGRESS_FILE="$SANDBOX/.progress"
TOTAL_STAGES=5

# Exit codes propagated from the practice subshell to the outer dispatcher.
RC_NEXT=0
RC_CHECK=96
RC_SHOW=97
RC_PREV=98
RC_QUIT=99

# ---------------------------------------------------------------------
# ANSI styling. Disabled when stdout isn't a TTY or NO_COLOR is set
# (https://no-color.org).
# ---------------------------------------------------------------------

if [ -t 1 ] && [ -z "${NO_COLOR:-}" ]; then
    H1=$'\e[1;38;5;208m'      # stage title — bold orange accent
    SUB=$'\e[1;38;5;244m'     # sub-section header — bold ash
    CMD=$'\e[1;38;5;220m'     # command to type — bold gold
    KEY=$'\e[38;5;208m'       # key combo — orange
    EM=$'\e[1;38;5;196m'      # warning / emphasis — bold red
    DIR=$'\e[38;5;109m'       # path / filename — steel
    INSTR=$'\e[1;38;5;208m'   # action footer — bold orange
    DIM=$'\e[2m'              # dim — inline comments
    OK=$'\e[1;38;5;46m'       # gate pass — bold green
    Q=$'\e[1;38;5;39m'        # gate question — bold blue
    RST=$'\e[0m'
else
    # shellcheck disable=SC1007  # multiple empty assignments on one line are intentional
    H1=''; SUB=''; CMD=''; KEY=''; EM=''; DIR=''; INSTR=''; DIM=''; OK=''; Q=''; RST=''
fi

# NOTE: do NOT `trap '' INT` here. SIG_IGN propagates across exec, bash
# inherits it, and Ctrl+C breaks inside the practice subshell — silently
# breaking the lessons that teach Ctrl+C. If the user Ctrl+Cs the parent
# script between lessons, the next run auto-resumes from .progress.

# ---------------------------------------------------------------------
# Usage / help
# ---------------------------------------------------------------------

usage() {
    cat <<EOF
shelltutor — a vimtutor prerequisite course (five mastery-gated stages).

Usage:
  shelltutor            resume where you left off
  shelltutor N          enter stage N (1..5) for re-take or first-time
  shelltutor -h         this help

Stages:
  1  Where am I?
  2  Paths and the filesystem
  3  Files and operations
  4  Commands, streams, composition
  5  Ready for vimtutor

Each stage closes with a gate: three recall questions (all three must be
correct) and one practical task (verified by the script). Passing means
passing — unlimited retries, no time pressure, no skip.

Inside the practice prompt:
  next   advance              show   redisplay current screen
  prev   go back              quit   leave (progress is saved)
  check  verify gate task (only at a gate)

Sandbox folder: $SANDBOX
(Override with SHELLTUTOR_HOME=/path ./shelltutor; NO_COLOR disables colour.)
EOF
}

# ---------------------------------------------------------------------
# Sandbox + progress
# ---------------------------------------------------------------------

setup_sandbox() {
    mkdir -p "$SANDBOX"
    # Educational fixtures used by Stage 4. Self-heal if removed.
    if [ ! -f "$SANDBOX/poem.txt" ]; then
        cat > "$SANDBOX/poem.txt" <<'POEM'
The terminal is a quiet room.
You speak to it, it answers back.
Words have shapes here, and shapes have weight.
A pipe is a doorway between rooms.
POEM
    fi
    if [ ! -f "$SANDBOX/numbers.txt" ]; then
        seq 1 50 > "$SANDBOX/numbers.txt"
    fi
    touch "$SANDBOX/.shelltutor_history"
}

setup_stage_dir() {
    local n=$1
    mkdir -p "$SANDBOX/stage${n}"
}

save_progress() {
    # Only advance, never regress. .progress = number of stages passed.
    local cur
    cur=$(read_progress)
    if [ "$1" -gt "$cur" ]; then
        echo "$1" > "$PROGRESS_FILE" 2>/dev/null || true
    fi
}

read_progress() {
    local n=0
    if [ -f "$PROGRESS_FILE" ]; then
        read -r n < "$PROGRESS_FILE" 2>/dev/null || n=0
        [[ "$n" =~ ^[0-9]+$ ]] || n=0
        # Defensive clamp. A pre-curriculum-redesign sandbox may carry
        # a .progress value in the old "next lesson index" semantics
        # (0..9). Anything above TOTAL_STAGES is treated as stale and
        # reset to 0 so the learner re-enters at Stage 1 rather than
        # being skipped to the finale.
        if [ "$n" -gt "$TOTAL_STAGES" ]; then n=0; fi
    fi
    echo "$n"
}

# ---------------------------------------------------------------------
# Practice subshell
#
# Spawns a real interactive bash with a sandboxed HISTFILE and PS1, in
# the requested working directory (defaults to $SANDBOX). The rcfile
# overrides five builtins so that the learner's navigation words exit
# with codes the outer dispatcher interprets:
#   next  -> 0   check -> 96   show -> 97   prev -> 98   quit/exit -> 99
# ---------------------------------------------------------------------

practice() {
    local pd="${1:-$SANDBOX}"
    setup_sandbox
    mkdir -p "$pd"
    bash --rcfile <(cat <<RCFILE
[ -r /etc/bashrc ] && . /etc/bashrc

cd "$pd"

HISTFILE="$SANDBOX/.shelltutor_history"
HISTSIZE=2000
HISTFILESIZE=4000
shopt -s histappend
history -r 2>/dev/null || true
PROMPT_COMMAND='history -a'

PS1='shelltutor> '

# Navigation: functions, not aliases, so alias chains can't recurse.
next()  { builtin exit  0; }
check() { builtin exit 96; }
prev()  { builtin exit 98; }
show()  { builtin exit 97; }
quit()  { builtin exit 99; }
exit()  { builtin exit 99; }

printf "\n${DIM}(Real shell.${RST}  ${CMD}next${RST}${DIM}=advance${RST}  ${CMD}show${RST}${DIM}=this screen again${RST}  ${CMD}quit${RST}${DIM}=leave${RST}${DIM}; ${RST}${CMD}check${RST}${DIM}=verify gate task)${RST}\n\n"
RCFILE
) -i < /dev/tty
    local code=$?
    if [ "$code" -eq $RC_QUIT ]; then
        clear 2>/dev/null || true
        echo "Bye. Run 'shelltutor' again to pick up where you left off."
        exit 0
    fi
    return "$code"
}

# ---------------------------------------------------------------------
# Lesson screen helper
# ---------------------------------------------------------------------

show_screen() {
    clear 2>/dev/null || printf '\n'
    cat
    echo
}

lesson() {
    show_screen
    practice "${1:-$SANDBOX}"
    return $?
}

# ---------------------------------------------------------------------
# Recall-question helper
#
# Usage: ask_question "<prompt>" <accepted-answer>...
# - Reads input from /dev/tty so it works inside the parent shell.
# - Normalizes by lowercasing + trimming whitespace.
# - Accepts the answer if it matches any of the trailing arguments
#   (also normalized). Loops until correct. No hints, no answer reveal.
# - Returns 0 on correct answer. (Quit via Ctrl+C at the parent shell.)
# ---------------------------------------------------------------------

ask_question() {
    local prompt="$1"; shift
    local accept=("$@")
    local ans norm ok_norm matched
    while true; do
        printf '%b%b%b\n' "$Q" "$prompt" "$RST"
        printf '  %byour answer:%b ' "$CMD" "$RST"
        if ! IFS= read -r ans < /dev/tty; then
            printf '\n'
            return 1
        fi
        norm=$(printf '%s' "$ans" | tr '[:upper:]' '[:lower:]' \
            | sed 's/^[[:space:]]*//; s/[[:space:]]*$//; s/[[:space:]]\+/ /g')
        matched=0
        for ok in "${accept[@]}"; do
            ok_norm=$(printf '%s' "$ok" | tr '[:upper:]' '[:lower:]' \
                | sed 's/^[[:space:]]*//; s/[[:space:]]*$//; s/[[:space:]]\+/ /g')
            if [ "$norm" = "$ok_norm" ]; then
                matched=1; break
            fi
        done
        if [ "$matched" -eq 1 ]; then
            printf '  %b✓%b\n\n' "$OK" "$RST"
            return 0
        fi
        printf '  %bnot quite. try again.%b\n\n' "$EM" "$RST"
    done
}

# ---------------------------------------------------------------------
# Gate task helper
#
# Renders a task screen, then loops practice() until verify() succeeds
# after a `check` exit code. Other exit codes:
#   show -> redisplay the task screen
#   prev -> redisplay the task screen (no cross-gate back-step)
#   next -> redisplay the task screen with a small nudge
#   quit -> exit (handled in practice())
# ---------------------------------------------------------------------

run_gate_task() {
    # $1: stage number; $2: task screen content (via stdin); rest: verify fn name
    local n=$1
    local verify=$2
    while true; do
        # Re-render task screen from caller's heredoc on first iteration
        # by reading it back from a stashed file in $SANDBOX. We use a
        # different pattern below: callers print the screen themselves
        # and then call this helper for the practice+verify loop.
        practice "$SANDBOX/stage${n}"
        local rc=$?
        case "$rc" in
            "$RC_CHECK")
                if "$verify"; then
                    printf '%b✓ Task verified.%b\n\n' "$OK" "$RST"
                    return 0
                fi
                printf '\n%bNot yet. Re-read the task and try again.%b\n' "$EM" "$RST"
                printf '%b(Type %bshow%b%b at the prompt to re-display the task screen.)%b\n\n' "$DIM" "$CMD" "$RST" "$DIM" "$RST"
                ;;
            "$RC_SHOW" | "$RC_PREV" | "$RC_NEXT")
                return "$rc"
                ;;
            *)
                return "$rc"
                ;;
        esac
    done
}

# ---------------------------------------------------------------------
# History helpers
# ---------------------------------------------------------------------

# Marks the current size of HISTFILE; later, history_since_marker shows
# only lines added since.
history_mark() {
    [ -f "$SANDBOX/.shelltutor_history" ] || touch "$SANDBOX/.shelltutor_history"
    wc -l < "$SANDBOX/.shelltutor_history" 2>/dev/null | tr -d '[:space:]'
}

history_since() {
    local mark=$1
    local total
    total=$(wc -l < "$SANDBOX/.shelltutor_history" 2>/dev/null | tr -d '[:space:]')
    if [ -z "$total" ] || [ "$total" -le "$mark" ]; then
        return 0
    fi
    tail -n "$((total - mark))" "$SANDBOX/.shelltutor_history"
}

# ---------------------------------------------------------------------
# STAGE 1 — Where am I?
# ---------------------------------------------------------------------

stage1_intro() {
    lesson <<EOF
${H1}STAGE 1 — Where am I?${RST}

Five short screens, then a gate. The gate has three recall questions
(all three must be correct) and one short task. You can retry as many
times as you like.

${SUB}WHAT'S A PROMPT?${RST}  The text the shell shows when it is ready
for you to type. Yours probably ends in ${KEY}\$${RST} or ${KEY}>${RST}.
In this tutor it is:
    ${DIM}shelltutor>${RST}

${SUB}FIVE WORDS STEER THE TUTOR${RST}:
  ${CMD}next${RST}   advance
  ${CMD}prev${RST}   go back
  ${CMD}show${RST}   re-display the current screen
  ${CMD}quit${RST}   leave the tutor (progress is saved; also: ${CMD}exit${RST})
  ${CMD}check${RST}  verify a gate task (only at a gate)

Your tutor work happens in ${DIR}${SANDBOX}${RST}.
The practice prompts run as ordinary commands in your account, so the
usual cautions apply. The tutor itself never reaches outside this folder.

${INSTR}▶ Type ${CMD}next${INSTR} to begin lesson 1.1.${RST}
EOF
    return $?
}

stage1_lesson_1() {
    lesson <<EOF
${H1}1.1 — running commands${RST}

${SUB}ECHO${RST} prints whatever you give it.
  ${CMD}echo hello${RST}
  ${CMD}echo I am at the shell${RST}     ${DIM}# words separated by spaces${RST}

When a command finishes, the prompt returns. That return-to-prompt is
how you know one command is done and the next one can start.

${SUB}KEYBOARD HABITS${RST}:
  ${KEY}Tab${RST}        complete what you started — try ${CMD}ls /et${RST} then Tab
  ${KEY}Tab Tab${RST}    list every match when several apply
  ${KEY}Ctrl+L${RST}     clear the screen
  ${KEY}Up Arrow${RST}   recall the last command (more in Stage 4)

${EM}Ctrl+C is the escape hatch.${RST}  Stuck prompt, command running
too long — press ${KEY}Ctrl+C${RST}. You will use it.

${INSTR}▶ Try a few echoes, then type ${CMD}next${INSTR}.${RST}
EOF
    return $?
}

stage1_lesson_2() {
    lesson <<EOF
${H1}1.2 — where am I, who am I, when is it${RST}

Three commands that ask the system about itself.

  ${CMD}whoami${RST}     ${DIM}# the user name you're logged in as${RST}
  ${CMD}pwd${RST}        ${DIM}# print working directory (the folder you're in)${RST}
  ${CMD}date${RST}       ${DIM}# the current date and time${RST}

In this practice prompt, ${CMD}pwd${RST} reports the tutor sandbox
folder. That's because the tutor ${CMD}cd${RST}'d here before handing
you the prompt — see Stage 2.

${SUB}CLEAR THE SCREEN${RST}.  ${KEY}Ctrl+L${RST}, or the command:
  ${CMD}clear${RST}

${INSTR}▶ Run all three, then type ${CMD}next${INSTR}.${RST}
EOF
    return $?
}

stage1_lesson_3() {
    lesson <<EOF
${H1}1.3 — what just happened${RST}

When you type ${CMD}whoami${RST} and press Enter:

  1. The terminal hands your line to ${SUB}the shell${RST}.
  2. The shell looks for a program named ${CMD}whoami${RST}.
  3. It runs it.
  4. The program prints to ${SUB}standard output${RST} — your screen.
  5. The shell shows the prompt again, ready for the next command.

The shell is not "Unix." It is a program — a ${SUB}command interpreter${RST}.
The terminal is a window that lets you talk to the shell. The program
${CMD}whoami${RST} is a third thing — it runs, prints, and exits.

You will keep these three apart for the rest of this tutor:
  ${SUB}terminal${RST}  →  ${SUB}shell${RST}  →  ${SUB}program${RST}

${INSTR}▶ Type ${CMD}next${INSTR} to take Stage 1's gate.${RST}
EOF
    return $?
}

stage1_gate_screen() {
    show_screen <<EOF
${H1}STAGE 1 — GATE${RST}

${SUB}Recall${RST} (three questions, all three must be correct).

Then a ${SUB}practical task${RST}: run a few commands and tell me what
they printed. The script verifies your answers.

${DIM}Unlimited retries. No skip.${RST}
EOF
}

stage1_verify_task() {
    # Re-read the values the learner reported. The four task questions
    # were asked just before this verification runs.
    [ "${TASK_S1_WHOAMI:-x}" = "$(whoami 2>/dev/null)" ] || return 1
    # pwd in practice subshell == $SANDBOX/stage1
    local expected_pwd="$SANDBOX/stage1"
    [ "${TASK_S1_PWD:-x}" = "$expected_pwd" ] || return 1
    # date day-of-week (e.g., Mon, Tue, ...)
    [ "${TASK_S1_DAY:-x}" = "$(date +%a 2>/dev/null)" ] || return 1
    return 0
}

stage1_gate() {
    stage1_gate_screen

    ask_question \
        "Q1: Which character usually ends a shell prompt? (\$, ;, :, or #)" \
        '$' || return $?

    ask_question \
        "Q2: What does ${CMD}pwd${RST} print?" \
        'the current working directory' \
        'current working directory' \
        'the working directory' \
        'working directory' \
        'the current folder' \
        'current folder' \
        'the folder im in' \
        'the folder i am in' || return $?

    ask_question \
        "Q3: After ${CMD}whoami${RST} runs, where does its output go?" \
        'stdout' \
        'standard output' \
        'the screen' \
        'screen' \
        'the terminal' \
        'terminal' || return $?

    # ---- Task: run three commands, then answer three short questions
    while true; do
        show_screen <<EOF
${H1}STAGE 1 — GATE TASK${RST}

Inside the practice prompt, run each of these once. Read each output.
Then type ${CMD}check${RST}.

  ${CMD}whoami${RST}
  ${CMD}pwd${RST}
  ${CMD}date${RST}

I will ask you what each one printed.

${INSTR}▶ When ready, you'll see ${DIM}shelltutor>${INSTR}. Type ${CMD}check${INSTR} when done.${RST}
EOF
        setup_stage_dir 1
        practice "$SANDBOX/stage1"
        local rc=$?
        case "$rc" in
            "$RC_CHECK")
                printf '%bThree short follow-ups based on what you saw.%b\n\n' "$SUB" "$RST"

                printf '%bWhat did %bwhoami%b print? (just the username)%b\n' "$Q" "$CMD" "$Q" "$RST"
                printf '  %byour answer:%b ' "$CMD" "$RST"
                IFS= read -r TASK_S1_WHOAMI < /dev/tty || return 1
                TASK_S1_WHOAMI=$(printf '%s' "$TASK_S1_WHOAMI" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')

                printf '\n%bWhat did %bpwd%b print? (paste the full path)%b\n' "$Q" "$CMD" "$Q" "$RST"
                printf '  %byour answer:%b ' "$CMD" "$RST"
                IFS= read -r TASK_S1_PWD < /dev/tty || return 1
                TASK_S1_PWD=$(printf '%s' "$TASK_S1_PWD" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')

                printf '\n%bWhat day of the week did %bdate%b show? (Mon, Tue, Wed, Thu, Fri, Sat, Sun)%b\n' "$Q" "$CMD" "$Q" "$RST"
                printf '  %byour answer:%b ' "$CMD" "$RST"
                IFS= read -r TASK_S1_DAY < /dev/tty || return 1
                TASK_S1_DAY=$(printf '%s' "$TASK_S1_DAY" | sed 's/^[[:space:]]*//; s/[[:space:]]*$//')
                # Normalize day to the 3-letter abbreviation
                TASK_S1_DAY=$(printf '%s' "$TASK_S1_DAY" \
                    | tr '[:lower:]' '[:upper:]' \
                    | sed 's/^\(...\).*/\1/' \
                    | sed 's/^./&/; s/\(.\)\(.\)\(.\)/\1\L\2\L\3/')

                if stage1_verify_task; then
                    printf '\n%b✓ Stage 1 cleared.%b\n\n' "$OK" "$RST"
                    save_progress 1
                    return 0
                fi
                printf '\n%bOne or more answers did not match. Let'\''s redo the task.%b\n\n' "$EM" "$RST"
                ;;
            "$RC_QUIT")
                return $rc
                ;;
            *)
                # show/prev/next at a gate → redisplay task
                ;;
        esac
    done
}

run_stage1() {
    local lessons=(stage1_intro stage1_lesson_1 stage1_lesson_2 stage1_lesson_3)
    local i=0
    while [ "$i" -lt "${#lessons[@]}" ]; do
        "${lessons[$i]}"
        local rc=$?
        case "$rc" in
            "$RC_NEXT")  ((i++)) ;;
            "$RC_SHOW")  : ;;
            "$RC_PREV")  i=$((i > 0 ? i - 1 : 0)) ;;
            *)         return "$rc" ;;
        esac
    done
    stage1_gate
}

