# ---------------------------------------------------------------------
# STAGE 4 — Commands, streams, composition
# ---------------------------------------------------------------------

stage4_intro() {
    lesson <<EOF
${H1}STAGE 4 — Commands, streams, composition${RST}

Three lessons, then a gate. You'll read a command's structure, check
whether a command exists, and chain commands together with pipes,
redirects, and globs.

Commands this stage:
  ${CMD}command -v${RST}   ask the shell if a program is installed
  ${CMD}wc${RST}           word, line, and character count
  ${CMD}seq${RST}           generate number sequences
  ${CMD}head${RST}          first N lines of input
  ${CMD}sort${RST}          sort lines
  ${CMD}grep${RST}          select lines matching a pattern
  ${CMD}|${RST}             ${SUB}pipe${RST}: send one command's output into the next
  ${CMD}>${RST}             ${SUB}redirect${RST}: write output to a file (overwrites)
  ${CMD}>>${RST}            ${SUB}append${RST}: add output to the end of a file
  ${CMD}<${RST}             ${SUB}input redirect${RST}: read a file into a command
  ${CMD}*${RST}             ${SUB}glob${RST}: match many filenames at once

${INSTR}▶ Type ${CMD}next${INSTR} to begin lesson 4.1.${RST}
EOF
}

stage4_lesson_1() {
    lesson <<EOF
${H1}4.1 — reading a command${RST}

A shell command has a small grammar:

  ${SUB}command  options  arguments${RST}

Examples:
  ${CMD}ls${RST}
  ${CMD}ls -l${RST}                    ${DIM}# one option, no argument${RST}
  ${CMD}ls -l /etc${RST}               ${DIM}# option + argument${RST}
  ${CMD}wc -l poem.txt${RST}           ${DIM}# count lines in a file${RST}
  ${CMD}echo "hello world"${RST}       ${DIM}# argument with a space — quoted${RST}

${EM}Spaces matter.${RST}  The shell splits on spaces. If a filename
has a space, ${SUB}quote it${RST} or the shell will see two arguments:

  ${CMD}vim "my notes.txt"${RST}       ${DIM}# opens one file${RST}
  ${CMD}vim my notes.txt${RST}         ${DIM}# opens TWO files: 'my' and 'notes.txt'${RST}

${SUB}command -v${RST} asks the shell whether a command exists.
  ${CMD}command -v ls${RST}            ${DIM}# prints the path; exits 0${RST}
  ${CMD}command -v vim${RST}           ${DIM}# does Vim exist on this system?${RST}
  ${CMD}command -v vimtutor${RST}      ${DIM}# does vimtutor?${RST}

${INSTR}▶ Try a few ${CMD}command -v${INSTR} probes, then ${CMD}next${INSTR}.${RST}
EOF
}

stage4_lesson_2() {
    lesson <<EOF
${H1}4.2 — the pipe${RST}

A ${SUB}pipe${RST} ( ${CMD}|${RST} ) sends the standard output of one
command into the standard input of the next. ${EM}Most important idea
in the shell.${RST}

${CMD}wc${RST} alone counts:
  ${CMD}wc -l poem.txt${RST}          ${DIM}# lines in poem.txt${RST}

${CMD}wc${RST} via pipe counts ${SUB}whatever you piped in${RST}:
  ${CMD}seq 1 100 | wc -l${RST}       ${DIM}# 100${RST}
  ${CMD}ls /usr/bin | wc -l${RST}     ${DIM}# how many programs are installed${RST}

Pipes stack:
  ${CMD}ls /usr/bin | sort | head${RST}        ${DIM}# list → sort → first 10${RST}
  ${CMD}ls /usr/bin | grep ^a${RST}            ${DIM}# names starting with 'a'${RST}
  ${CMD}ls /usr/bin | grep ^a | wc -l${RST}    ${DIM}# …and count them${RST}

Things to notice while you try these:
  - ${CMD}|${RST} is Shift+Backslash on most keyboards.
  - Each piece is a normal command; only the connector is new.
  - The pipeline runs left-to-right; output flows.

${INSTR}▶ Try a few pipelines, then ${CMD}next${INSTR}.${RST}
EOF
}

stage4_lesson_3() {
    lesson <<EOF
${H1}4.3 — redirection and globs${RST}

A pipe sends output to ${SUB}another program${RST}. A redirect sends it
to ${SUB}a file${RST}.

  ${CMD}>${RST}    write to a file (${EM}overwrites${RST} if it exists)
  ${CMD}>>${RST}   append to a file (creates if missing)
  ${CMD}<${RST}    read a file ${SUB}into${RST} a command

Examples:
  ${CMD}echo first > greeting.txt${RST}        ${DIM}# overwrite${RST}
  ${CMD}echo second >> greeting.txt${RST}      ${DIM}# append${RST}
  ${CMD}cat greeting.txt${RST}                 ${DIM}# two lines${RST}
  ${CMD}wc -w < poem.txt${RST}                 ${DIM}# count words read from poem.txt${RST}

Combine with pipes:
  ${CMD}ls /usr/bin | sort > programs.txt${RST}
  ${CMD}wc -l programs.txt${RST}

${SUB}Globs${RST} match many filenames at once. The shell expands them
${SUB}before${RST} the command sees them.

  ${CMD}ls *.txt${RST}              ${DIM}# every .txt file in this folder${RST}
  ${CMD}wc -l *.txt${RST}           ${DIM}# count lines in each .txt file${RST}
  ${CMD}cat *.txt${RST}             ${DIM}# print them all back-to-back${RST}

${EM}Predict before you act.${RST}  ${CMD}rm *${RST} removes everything
in the current folder. ${CMD}rm *.tmp${RST} removes only .tmp files.

${INSTR}▶ Type ${CMD}next${INSTR} to take Stage 4's gate.${RST}
EOF
}

stage4_verify_task() {
