stage3_intro() {
    lesson <<EOF
${H1}STAGE 3 — Files and operations${RST}

Three lessons, then a gate. You'll create, read, copy, move, and remove
files. ${EM}rm is immediate.${RST} It does not move things to a trash.
We'll do everything inside ${DIR}${SANDBOX}/stage3${RST} so practice is
contained.

Commands this stage:
  ${CMD}touch${RST}   create an empty file (or update its timestamp)
  ${CMD}mkdir${RST}   create a folder
  ${CMD}rmdir${RST}   remove an EMPTY folder
  ${CMD}cat${RST}     print a text file
  ${CMD}less${RST}    page through a long file (exit with ${KEY}q${RST})
  ${CMD}cp${RST}      copy
  ${CMD}mv${RST}      move (or rename — same command)
  ${CMD}rm${RST}      remove a file (${EM}immediate${RST})

${INSTR}▶ Type ${CMD}next${INSTR} to begin lesson 3.1.${RST}
EOF
}

stage3_lesson_1() {
    lesson <<EOF
${H1}3.1 — creating: touch, mkdir${RST}

${CMD}touch${RST} creates an empty file (or updates the timestamp of
an existing one).
  ${CMD}touch hello.txt${RST}
  ${CMD}ls${RST}              ${DIM}# you should see hello.txt${RST}

${CMD}mkdir${RST} creates a folder.
  ${CMD}mkdir notes${RST}
  ${CMD}ls${RST}              ${DIM}# notes/ is now there${RST}

To create a file ${SUB}with content${RST}, use redirection (Stage 4):
  ${CMD}echo "first line" > greeting.txt${RST}

But for now, ${CMD}touch${RST} for empty files, ${CMD}mkdir${RST} for
folders.

${INSTR}▶ Make a few, then ${CMD}next${INSTR}.${RST}
EOF
}

stage3_lesson_2() {
    lesson <<EOF
${H1}3.2 — reading: cat, less${RST}

${CMD}cat${RST} prints the entire file at once.
  ${CMD}cat hello.txt${RST}                ${DIM}# probably empty${RST}
  ${CMD}cat ~/.shelltutor/poem.txt${RST}   ${DIM}# the tutor's poem fixture${RST}

For a long file, ${CMD}cat${RST} floods the screen. Use ${CMD}less${RST}
to page through it:
  ${CMD}less ~/.shelltutor/poem.txt${RST}

Inside ${CMD}less${RST}, the screen takes over. Press ${KEY}Space${RST}
or ${KEY}f${RST} to page down, ${KEY}b${RST} to page back, and
${KEY}q${RST} to exit. (More on full-screen programs in Stage 5.)

${EM}Important:${RST} when ${CMD}less${RST} takes over, the prompt is
gone. You're inside a program. ${KEY}q${RST} returns you to the shell.

${INSTR}▶ Try both, then ${CMD}next${INSTR}.${RST}
EOF
}

stage3_lesson_3() {
    lesson <<EOF
${H1}3.3 — copy, move, delete${RST}

${CMD}cp${RST} copies. The original stays.
  ${CMD}cp hello.txt backup.txt${RST}

${CMD}mv${RST} moves. The original moves to the new name or folder.
The same command is used for ${SUB}rename${RST}:
  ${CMD}mv hello.txt hi.txt${RST}            ${DIM}# rename${RST}
  ${CMD}mv hi.txt notes/${RST}               ${DIM}# move into a folder${RST}

${CMD}rm${RST} deletes. ${EM}Immediately and permanently.${RST}
  ${CMD}rm backup.txt${RST}

There is no Trash to recover from. There is no undo. ${EM}Type
carefully and look before you press Enter.${RST}

${SUB}A safety habit${RST}: list before you remove.
  ${CMD}ls${RST}
  ${CMD}rm <only-now-that-you-are-sure>${RST}

${INSTR}▶ Type ${CMD}next${INSTR} to take Stage 3's gate.${RST}
EOF
}

stage3_verify_task() {
    [ -f "$SANDBOX/stage3/done.txt" ] || return 1
    [ ! -f "$SANDBOX/stage3/notes.txt" ] || return 1
    [ ! -f "$SANDBOX/stage3/backup.txt" ] || return 1
    grep -q 'hello' "$SANDBOX/stage3/done.txt" || return 1
    return 0
}

stage3_gate() {
    show_screen <<EOF
${H1}STAGE 3 — GATE${RST}

${SUB}Recall${RST} (three questions, all three must be correct).
Then a ${SUB}practical task${RST}.
EOF

    ask_question \
        "Q1: Which command creates an empty file?  (touch, mkdir, new, cat)" \
        'touch' || return $?

    ask_question \
        "Q2: After ${CMD}rm important.txt${RST}, where is the file?  (~/.Trash, on disk, gone, depends)" \
        'gone' \
        "it's gone" \
        'its gone' || return $?

    ask_question \
        "Q3: What single command renames ${DIR}old.txt${RST} to ${DIR}new.txt${RST}?" \
        'mv' \
        'mv old.txt new.txt' \
        'mv old new' || return $?

    # Clean slate once at gate entry. Learner state then persists across
